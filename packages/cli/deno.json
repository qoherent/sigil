{
  "name": "@qoherent/sigil",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "architecture.md",
      "spec.md",
      "src/**/*.ts"
    ],
    "exclude": [
      "tests/"
    ]
  },
  "tasks": {
    "install": "deno install --global --force --config ../../deno.json --allow-read --allow-write --allow-env=HOME,USERPROFILE --name sigil src/main.ts",
    "test": "deno test --allow-read --allow-write --allow-run",
    "publish:dry-run": "deno publish --dry-run"
  },
  "compilerOptions": {
    "strict": true
  }
}
