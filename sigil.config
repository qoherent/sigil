{
  "configVersion": "1.0.0",
  "languageVersion": "1.0.0",
  "workspace": {
    "name": "sigil",
    "members": [
      "packages/sigil-cli"
    ]
  },
  "files": {
    "include": [
      "**/*.sigil"
    ],
    "exclude": [
      ".git/**",
      ".deno/**",
      "node_modules/**",
      "build/**",
      "coverage/**",
      "examples/**"
    ]
  },
  "tools": {}
}
