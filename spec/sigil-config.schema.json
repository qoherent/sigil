{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/qoherent/sigil/blob/main/spec/sigil-config.schema.json",
  "title": "Sigil workspace configuration",
  "type": "object",
  "$defs": {
    "glob": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "member": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.$)(?!/)(?![A-Za-z]:[\\\\/])(?!.*\\\\)(?!\\./)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*\\/$).+$"
    }
  },
  "additionalProperties": false,
  "required": ["sigilVersion", "workspace", "files"],
  "properties": {
    "sigilVersion": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S(?:[\\s\\S]*\\S)?$"
        },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/member" },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["include"],
      "properties": {
        "include": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/glob" },
          "default": ["**/*.sigil"]
        },
        "exclude": {
          "type": "array",
          "items": { "$ref": "#/$defs/glob" },
          "default": [
            ".git/**",
            ".deno/**",
            "node_modules/**",
            "build/**",
            "coverage/**"
          ]
        }
      }
    },
    "tools": {
      "type": "object",
      "propertyNames": { "minLength": 1 },
      "additionalProperties": { "type": "object" },
      "default": {}
    }
  }
}
