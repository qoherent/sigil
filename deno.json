{
  "name": "@qoherent/qode",
  "version": "0.1.0",
  "exports": {
    ".": "./src/main.ts",
    "./main": "./src/main.ts"
  },
  "tasks": {
    "dev": "deno run --watch --allow-net src/main.ts",
    "test": "deno test --allow-net tests/",
    "check": "deno check src/main.ts tests/**/*.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "build": "deno compile --allow-net --output build/qode src/main.ts",
    "build:install": "deno compile --allow-net --output ~/.local/bin/qode src/main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom"],
    "strict": true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-unused-vars", "no-explicit-any"]
    }
  },
  "test": {
    "include": ["tests/"],
    "exclude": ["build/", "node_modules/"]
  }
}
